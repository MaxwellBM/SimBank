# Puerto del backend
PORT=8080

# Conexión a PostgreSQL
POSTGRES_DSN=postgres://banca:banca_password@localhost:5432/banca_db?sslmode=disable

# Dirección del clúster TigerBeetle
TIGERBEETLE_ADDRESS=localhost:3000
TIGERBEETLE_CLUSTER_ID=0

# Secreto para firmar JWT (cambiar en producción)
JWT_SECRET=dev-secret-change-in-production

# API Key de OpenRouter para el chat con IA
OPENROUTER_API_KEY=

# Modelo de IA a usar vía OpenRouter
AI_MODEL=openai/gpt-4o

# Ruta al archivo de datos de prueba para sembrar
SEED_DATA_PATH=./data/datos-prueba-HNL.json
