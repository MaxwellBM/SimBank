# ──────────────────────────────────────────────
# SimBank — Variables de Entorno
# ──────────────────────────────────────────────
# Copia este archivo como .env y ajusta los valores.

# Puerto del servidor backend (default: 8080)
PORT=8080

# Cadena de conexión a PostgreSQL
# Formato: postgres://usuario:contraseña@host:puerto/base_de_datos?sslmode=disable
POSTGRES_DSN=postgres://banca:banca_password@postgres:5432/banca_db?sslmode=disable

# Dirección del nodo de TigerBeetle (host:puerto)
# En Docker Compose usa el nombre del servicio
TIGERBEETLE_ADDRESS=tigerbeetle:3000

# ID del clúster de TigerBeetle (default: 0)
TIGERBEETLE_CLUSTER_ID=0

# Secreto para firmar JWT — CÁMBIALO en producción
JWT_SECRET=dev-secret-change-in-production

# API Key de OpenRouter para el chat con IA
# Déjalo vacío si no quieres usar el chat (el endpoint devolverá 503)
OPENROUTER_API_KEY=

# Modelo de IA a usar vía OpenRouter (default: openai/gpt-4o)
AI_MODEL=openai/gpt-4o

# Ruta al archivo JSON con datos de prueba para el seed
# (relativa al contenedor, no al host)
SEED_DATA_PATH=/app/data/datos-prueba-HNL.json
